<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GitCraft IDE - Game & VR</title>
    <!-- Three.js para la habitación 3D/VR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        :root {
            --bg-color: #0d1117;
            --panel-color: #161b22;
            --border-color: #30363d;
            --text-color: #c9d1d9;
            --accent-color: #238636;
            --error-color: #f85149;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }
        body, html { width: 100%; height: 100%; background-color: var(--bg-color); color: var(--text-color); overflow: hidden; }

        /* Contenedor Principal */
        #app-container { display: flex; width: 100%; height: 100vh; position: relative; }

        /* Interfaz estilo GitHub Gamificado */
        #sidebar { width: 260px; background: var(--panel-color); border-right: 1px solid var(--border-color); display: flex; flex-direction: column; padding: 15px; }
        #editor-zone { flex: 1; display: flex; flex-direction: column; background: var(--bg-color); position: relative; }
        #ai-assistant { width: 300px; background: var(--panel-color); border-left: 1px solid var(--border-color); display: flex; flex-direction: column; }

        /* Gamificación Stats */
        .stat-box { background: #21262d; padding: 10px; border-radius: 6px; margin-bottom: 15px; border: 1px solid var(--border-color); }
        .progress-bar { background: #30363d; height: 8px; border-radius: 4px; margin-top: 5px; overflow: hidden; }
        .progress-fill { background: var(--accent-color); height: 100%; width: 35%; transition: width 0.3s; }

        /* Editor de Código */
        .editor-header { height: 45px; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; padding: 0 15px; justify-content: space-between; background: var(--panel-color); }
        .editor-wrapper { flex: 1; position: relative; }
        textarea { width: 100%; height: 100%; background: transparent; border: none; color: #e6edf3; font-family: 'Courier New', Courier, monospace; font-size: 16px; padding: 15px; resize: none; outline: none; line-height: 1.5; }
        #error-log { position: absolute; bottom: 0; width: 100%; background: rgba(248, 81, 73, 0.15); border-top: 1px solid var(--error-color); color: #ff7b72; padding: 10px 15px; font-size: 14px; display: none; }

        /* Panel de IA */
        .ai-header { padding: 15px; border-bottom: 1px solid var(--border-color); font-weight: bold; display: flex; align-items: center; gap: 8px; }
        .ai-messages { flex: 1; padding: 15px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; font-size: 14px; }
        .msg { padding: 8px 12px; border-radius: 6px; max-width: 85%; }
        .msg.user { background: #21262d; align-self: flex-end; }
        .msg.ai { background: #23863622; border: 1px solid #23863655; align-self: flex-start; }
        .ai-input-zone { padding: 10px; border-top: 1px solid var(--border-color); display: flex; gap: 8px; }
        .ai-input-zone input { flex: 1; background: #21262d; border: 1px solid var(--border-color); border-radius: 6px; padding: 8px; color: white; outline: none; }
        .ai-input-zone button { background: var(--accent-color); border: none; color: white; padding: 8px 12px; border-radius: 6px; cursor: pointer; }

        /* Botón VR */
        .btn-vr { background: #1f6feb; color: white; border: none; padding: 10px; border-radius: 6px; cursor: pointer; font-weight: bold; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: auto; }

        /* Vista de Habitación VR */
        #vr-canvas-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: none; z-index: 10; }
        #exit-vr { position: absolute; top: 20px; right: 20px; z-index: 11; background: var(--error-color); color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>

    <div id="app-container">
        <!-- BARRA LATERAL (Gamificación) -->
        <div id="sidebar">
            <h2 style="font-size: 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">🐙 GitCraft</h2>
            
            <div class="stat-box">
                <div><strong>Nivel 5</strong> Coder</div>
                <div class="progress-bar"><div class="progress-fill" id="xp-bar"></div></div>
                <div style="font-size: 12px; color: #8b949e; margin-top: 5px;" id="xp-text">350 / 1000 XP</div>
            </div>

            <div class="stat-box">
                <div>Racha: <span style="color: #f9826c;">🔥 7 Días</span></div>
                <div>Logros: 🏆 12/50</div>
            </div>

            <button class="btn-vr" onclick="toggleVR(true)">🥽 Entrar a Cuarto VR</button>
        </div>

        <!-- ZONA DEL EDITOR (Sintaxis en vivo) -->
        <div id="editor-zone">
            <div class="editor-header">
                <span style="font-family: monospace;">main.js</span>
                <span id="save-status" style="color: #8b949e; font-size: 14px;">Autoguardado activo</span>
            </div>
            <div class="editor-wrapper">
                <textarea id="code-editor" placeholder="// Escribe tu código JavaScript aquí...&#10;// Intenta dejar una llave abierta '{' para ver el detector de errores en tiempo real." oninput="checkCode()"></textarea>
                <div id="error-log"></div>
            </div>
        </div>

        <!-- ASISTENTE DE IA (Ilimitado) -->
        <div id="ai-assistant">
            <div class="ai-header">🤖 Copilot IA <span style="background:#238636; font-size:10px; padding:2px 6px; border-radius:10px; margin-left:5px;">ILIMITADO</span></div>
            <div class="ai-messages" id="ai-messages">
                <div class="msg ai">¡Hola! Soy tu IA de soporte. Puedo autocompletar, corregir o escribir funciones enteras. ¿Qué programamos hoy?</div>
            </div>
            <div class="ai-input-zone">
                <input type="text" id="ai-input" placeholder="Pregúntale a la IA..." onkeypress="if(event.key === 'Enter') askAI()">
                <button onclick="askAI()">Enviar</button>
            </div>
        </div>
    </div>

    <!-- CONTENEDOR PARA LA HABITACIÓN VR 3D -->
    <div id="vr-canvas-container">
        <button id="exit-vr" onclick="toggleVR(false)">Salir de VR x</button>
    </div>

    <script>
        // --- 1. DETECTOR DE ERRORES EN VIVO Y RECOMPENSAS ---
        let xp = 350;
        function checkCode() {
            const code = document.getElementById('code-editor').value;
            const errorLog = document.getElementById('error-log');
            
            try {
                // Evaluamos sintaxis de forma segura mediante una función constructora
                new Function(code);
                errorLog.style.display = 'none';
                
                // Dar XP por escribir código válido de forma aleatoria
                if(code.length % 15 === 0 && code.length > 0) {
                    gainXP(15);
                }
            } catch (err) {
                // Si hay error de sintaxis, se muestra en vivo abajo del editor
                errorLog.innerText = `⚠️ Error de Sintaxis: ${err.message}`;
                errorLog.style.display = 'block';
            }
        }

        function gainXP(amount) {
            xp += amount;
            if(xp >= 1000) xp = 0; // Reset rápido para el demo
            document.getElementById('xp-bar').style.width = (xp / 1000 * 100) + '%';
            document.getElementById('xp-text').innerText = `${xp} / 1000 XP`;
        }

        // --- 2. IA ILIMITADA (Simulador Avanzado de Contexto Local) ---
        function askAI() {
            const input = document.getElementById('ai-input');
            const container = document.getElementById('ai-messages');
            const codeEditor = document.getElementById('code-editor');
            
            if(!input.value.trim()) return;

            // Mensaje de usuario
            const userMsg = document.createElement('div');
            userMsg.className = 'msg user';
            userMsg.innerText = input.value;
            container.appendChild(userMsg);

            const query = input.value.toLowerCase();
            let responseText = "Entendido. Analizando tu espacio de trabajo para optimizar la estructura...";

            // Respuestas inteligentes basadas en programación web/GD triggers
            if(query.includes('crear') || query.includes('hacer un juego')) {
                responseText = "¡Hagamos un juego básico! Aquí tienes una plantilla de bucle de juego:\n\nfunction update() {}\nfunction render() {}\nfunction loop() {\n  update();\n  render();\n  requestAnimationFrame(loop);\n}";
                codeEditor.value += (codeEditor.value ? "\n" : "") + "function update() {}\nfunction render() {}\nfunction loop() {\n  update();\n  render();\n  requestAnimationFrame(loop);\n}\nloop();";
                gainXP(50);
            } else if(query.includes('error') || query.includes('arreglar')) {
                responseText = "Revisé tu sintaxis. Asegúrate de cerrar todos los paréntesis '()' y llaves '{}'. He limpiado las advertencias comunes.";
            } else if(query.includes('bucle') || query.includes('for')) {
                responseText = "Aquí tienes un bucle estándar optimizado:\nfor(let i = 0; i < 10; i++) {\n    console.log('Iteración:', i);\n}";
            }

            // Simular retraso de procesamiento de la IA
            setTimeout(() => {
                const aiMsg = document.createElement('div');
                aiMsg.className = 'msg ai';
                aiMsg.innerText = responseText;
                container.appendChild(aiMsg);
                container.scrollTop = container.scrollHeight;
                checkCode();
            }, 600);

            input.value = '';
            container.scrollTop = container.scrollHeight;
        }

        // --- 3. HABITACIÓN VIRTUAL 3D / MODO VR (Three.js) ---
        let scene, camera, renderer, room;

        function init3DRoom() {
            const container = document.getElementById('vr-canvas-container');
            
            // Crear escena y cámara
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x0a0e14);
            
            camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 1.6, 3); // Altura de los ojos humanos en metros

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            container.appendChild(renderer.domElement);

            // Luz ambiental e intensa hacia el escritorio
            const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambientLight);
            
            const deskLight = new THREE.PointLight(0x58a6ff, 1, 10);
            deskLight.position.set(0, 2, 0);
            scene.add(deskLight);

            // Crear el cuarto (Paredes)
            const roomGeo = new THREE.BoxGeometry(6, 4, 6);
            const roomMat = new THREE.MeshStandardMaterial({ color: 0x161b22, side: THREE.BackSide });
            room = new THREE.Mesh(roomGeo, roomMat);
            room.position.y = 2;
            scene.add(room);

            // Escritorio de programación
            const deskGeo = new THREE.BoxGeometry(2, 0.1, 0.8);
            const deskMat = new THREE.MeshStandardMaterial({ color: 0x30363d });
            const desk = new THREE.Mesh(deskGeo, deskMat);
            desk.position.set(0, 0.9, -1);
            scene.add(desk);

            // Monitor de la Computadora (Donde se vería el código)
            const monitorGeo = new THREE.BoxGeometry(1.2, 0.7, 0.05);
            const monitorMat = new THREE.MeshStandardMaterial({ color: 0x0d1117, emissive: 0x238636, emissiveIntensity: 0.2 });
            const monitor = new THREE.Mesh(monitorGeo, monitorMat);
            monitor.position.set(0, 1.4, -1.2);
            scene.add(monitor);

            // Soporte del monitor
            const standGeo = new THREE.BoxGeometry(0.1, 0.4, 0.1);
            const standMat = new THREE.MeshStandardMaterial({ color: 0x21262d });
            const stand = new THREE.Mesh(standGeo, standMat);
            stand.position.set(0, 1.1, -1.2);
            scene.add(stand);

            // Animación / Renderizado básico
            function animate() {
                requestAnimationFrame(animate);
                // Movimiento sutil orbital automático para simular un ambiente vivo si no hay gafas VR conectadas
                monitor.rotation.y = Math.sin(Date.now() * 0.001) * 0.05;
                renderer.render(scene, camera);
            }
            animate();
        }

        function toggleVR(show) {
            const vrContainer = document.getElementById('vr-canvas-container');
            if (show) {
                vrContainer.style.display = 'block';
                if(!renderer) init3DRoom(); // Inicializa solo la primera vez
            } else {
                vrContainer.style.display = 'none';
            }
        }

        // Ajustar tamaño si cambia la pantalla de la tablet/celular
        window.addEventListener('resize', () => {
            if(camera && renderer) {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            }
        });
    </script>
</body>
</html>
